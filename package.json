{
  "name": "light-dbt",
  "displayName": "Light dbt",
  "description": "Lightweight VS Code extension for interacting with dbt through the dbt CLI.",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:sql",
    "onLanguage:jinja-sql"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dbtAutoComplete.refreshManifest",
        "title": "Light dbt: Refresh Manifest"
      },
      {
        "command": "dbtAutoComplete.showLineage",
        "title": "Light dbt: Show Lineage"
      },
      {
        "command": "dbtAutoComplete.refreshLineage",
        "title": "Light dbt: Refresh Lineage"
      },
      {
        "command": "dbtAutoComplete.showCompiledModel",
        "title": "Light dbt: Show Compiled Model"
      },
      {
        "command": "dbtAutoComplete.recompileAndShowModel",
        "title": "Light dbt: Recompile and Show Model"
      },
      {
        "command": "dbtAutoComplete.showManifestPicker",
        "title": "Light dbt: Picker"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbtAutoComplete",
          "title": "Light dbt",
          "icon": "media/dbt.svg"
        }
      ]
    },
    "views": {
      "dbtAutoComplete": [
        {
          "id": "dbtAutoComplete.lineage",
          "name": "Lineage"
        }
      ]
    },
    "configuration": {
      "title": "Light dbt",
      "properties": {
        "dbtAutoComplete.manifestRelativePath": {
          "type": "string",
          "default": "target/manifest.json",
          "description": "Relative path from the workspace root to the primary dbt manifest artifact."
        },
        "dbtAutoComplete.lineage.maxNodes": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Maximum total number of lineage nodes to materialize across upstream and downstream branches."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "build": "tsc -p ./",
    "package:vsix": "npx @vscode/vsce package",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.7.2"
  }
}
